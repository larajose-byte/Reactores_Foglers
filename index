<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guía de Notebooks — Diseño de Reactores | Maestría Ingeniería Química</title>
<style>
/* Fuentes: stack serif para títulos, sans-serif para cuerpo, mono para código */
</style>
<style>
/* ─── Variables ─────────────────────────────────────────── */
:root {
  --ink:       #18202C;
  --ink-soft:  #3D4D60;
  --muted:     #7A8A9A;
  --border:    #DDE4EE;
  --bg-page:   #F0F4F9;
  --bg-card:   #FFFFFF;
  --bg-alt:    #F7FAFD;

  /* Accent per notebook */
  --c1:  #1A56C4;  --c1l: #EBF0FD;  --c1m: #3B72E0;
  --c2:  #B5320D;  --c2l: #FDEEE9;  --c2m: #D94E2A;
  --c3:  #1A7A42;  --c3l: #E7F6ED;  --c3m: #2EA05A;
  --c4:  #5E28A0;  --c4l: #F1EBFA;  --c4m: #7B42C2;
  --c5:  #0E6F7E;  --c5l: #E5F4F7;  --c5m: #1892A5;
  --c6:  #A01C1C;  --c6l: #FAE8E8;  --c6m: #C83030;
}

/* ─── Reset ─────────────────────────────────────────────── */
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  font-family: 'Segoe UI', 'Liberation Sans', Arial, sans-serif;
  background: var(--bg-page);
  color: var(--ink);
  line-height: 1.65;
  font-size: 15px;
}

/* ─── Utility ────────────────────────────────────────────── */
.mono { font-family: 'Consolas', 'Courier New', monospace; }
code  { font-family: 'Consolas', 'Courier New', monospace; font-size:.84em;
        background:#EEF3FA; color:#1A56C4; padding:.12em .42em;
        border-radius:4px; }

/* ─── HERO ───────────────────────────────────────────────── */
.hero {
  background: #FFFFFF;
  border-bottom: 1px solid var(--border);
  padding: 3.8rem 2rem 3rem;
  text-align: center;
}
.hero-eyebrow {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size:.72rem; font-weight:500;
  letter-spacing:.16em; text-transform:uppercase;
  color: var(--muted); margin-bottom:1.1rem;
}
.hero h1 {
  font-family: Georgia, 'Times New Roman', serif; font-weight:700;
  font-size: clamp(2rem,4.5vw,3.2rem);
  color: var(--ink); line-height:1.15;
  margin-bottom:.9rem;
}
.hero h1 em { font-style:italic; color: var(--c1); }
.hero-desc {
  font-size:1.02rem; color: var(--ink-soft);
  max-width:600px; margin:0 auto 2rem;
  font-weight:300;
}
.hero-chips {
  display:flex; gap:.6rem; flex-wrap:wrap; justify-content:center;
}
.chip {
  background: var(--bg-alt);
  border:1px solid var(--border);
  border-radius:100px;
  padding:.3rem .9rem;
  font-size:.78rem; font-weight:500;
  color: var(--ink-soft);
}

/* ─── TOP NAV ────────────────────────────────────────────── */
.top-nav {
  position:sticky; top:0; z-index:80;
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(10px);
  border-bottom:1px solid var(--border);
  padding:.6rem 1rem;
  display:flex; gap:.4rem; flex-wrap:wrap; justify-content:center;
}
.nav-btn {
  display:inline-flex; align-items:center; gap:.35rem;
  padding:.32rem .85rem;
  border-radius:6px;
  font-size:.74rem; font-weight:600;
  text-decoration:none; border:none; cursor:pointer;
  transition: background .18s, transform .12s;
  border: 1.5px solid transparent;
}
.nav-btn:hover { transform:translateY(-1px); }

/* ─── MAIN LAYOUT ────────────────────────────────────────── */
.page-wrap { max-width:980px; margin:0 auto; padding:2.5rem 1.5rem 5rem; }

/* ─── NOTEBOOK CARD ──────────────────────────────────────── */
.nb {
  background: var(--bg-card);
  border-radius:14px;
  border:1px solid var(--border);
  margin-bottom:3.5rem;
  overflow:hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,.06);
  animation: riseIn .45s ease both;
}
@keyframes riseIn {
  from { opacity:0; transform:translateY(16px); }
  to   { opacity:1; transform:translateY(0); }
}
.nb:nth-child(1){animation-delay:.05s}
.nb:nth-child(2){animation-delay:.10s}
.nb:nth-child(3){animation-delay:.15s}
.nb:nth-child(4){animation-delay:.20s}
.nb:nth-child(5){animation-delay:.25s}
.nb:nth-child(6){animation-delay:.30s}

/* ─── CARD HEADER ────────────────────────────────────────── */
.nb-head {
  padding:1.8rem 2rem 1.4rem;
  border-bottom:1px solid var(--border);
  display:flex; align-items:flex-start; gap:1.2rem;
}
.nb-badge {
  width:52px; height:52px; border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.55rem; flex-shrink:0;
}
.nb-head-text { flex:1; }
.nb-num {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size:.68rem; font-weight:500; letter-spacing:.12em;
  text-transform:uppercase; margin-bottom:.3rem;
}
.nb-title {
  font-family: Georgia, 'Times New Roman', serif; font-weight:700;
  font-size:1.42rem; line-height:1.2; color:var(--ink);
  margin-bottom:.25rem;
}
.nb-sub {
  font-size:.82rem; color:var(--muted); font-style:italic;
}
.nb-tags { display:flex; gap:.4rem; flex-wrap:wrap; margin-top:.65rem; }
.tag {
  font-size:.68rem; font-weight:600; padding:.2rem .6rem;
  border-radius:20px; letter-spacing:.04em; text-transform:uppercase;
}

/* ─── CARD BODY ──────────────────────────────────────────── */
.nb-body { padding:1.8rem 2rem; }

/* ─── SECTION HEADINGS ───────────────────────────────────── */
.sec-head {
  font-family: Georgia, 'Times New Roman', serif; font-weight:700;
  font-size:1rem; color:var(--ink);
  display:flex; align-items:center; gap:.6rem;
  margin:2rem 0 .9rem;
}
.sec-head::after {
  content:''; flex:1; height:1px; background:var(--border);
}

/* ─── PROSE ──────────────────────────────────────────────── */
.prose {
  font-size:.94rem; color: var(--ink-soft);
  line-height:1.78; margin-bottom:.9rem;
}
.prose strong { color:var(--ink); font-weight:600; }

/* ─── STEPS ──────────────────────────────────────────────── */
.steps { display:flex; flex-direction:column; gap:.8rem; margin:1rem 0; }
.step {
  display:flex; gap:1rem; align-items:flex-start;
  padding:.9rem 1.1rem;
  background: var(--bg-alt);
  border-radius:10px;
  border-left:3px solid transparent;
}
.step-n {
  width:28px; height:28px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family: 'Consolas', 'Courier New', monospace;
  font-size:.75rem; font-weight:500;
  flex-shrink:0; margin-top:.05rem;
}
.step-txt { flex:1; }
.step-title { font-weight:600; font-size:.92rem; margin-bottom:.25rem; }
.step-desc  { font-size:.87rem; color:var(--ink-soft); line-height:1.65; }

/* ─── EQ BOX ─────────────────────────────────────────────── */
.eq {
  background:#FFFDF0;
  border:1.5px solid #DEBB50;
  border-radius:8px;
  padding:.85rem 1.1rem;
  font-family: 'Consolas', 'Courier New', monospace;
  font-size:.86rem; color:#3A2800; line-height:1.65;
  margin:.8rem 0;
}
.eq-lbl {
  font-family: 'Segoe UI', 'Liberation Sans', Arial, sans-serif;
  font-size:.68rem; font-weight:600; text-transform:uppercase;
  letter-spacing:.08em; color:#8A6500; margin-bottom:.35rem;
}

/* ─── DATA TABLE ─────────────────────────────────────────── */
.dtable { width:100%; border-collapse:collapse; margin:1rem 0; font-size:.87rem; }
.dtable th {
  background:var(--ink); color:#fff;
  padding:.55rem .9rem; text-align:left;
  font-size:.76rem; letter-spacing:.05em; text-transform:uppercase; font-weight:500;
}
.dtable td {
  padding:.5rem .9rem; border-bottom:1px solid var(--border); color:var(--ink-soft);
}
.dtable tr:hover td { background:#F8FBFF; }
.dtable tr:last-child td { border-bottom:none; }

/* ─── TWO-COL COMPARE ────────────────────────────────────── */
.compare {
  display:grid; grid-template-columns:1fr 1fr;
  gap:.8rem; margin:1rem 0;
}
@media(max-width:640px){ .compare{grid-template-columns:1fr;} }
.compare-col {
  border-radius:10px; padding:1.1rem 1.2rem;
  border:1px solid var(--border);
}
.compare-col h4 { font-size:.85rem; font-weight:600; margin-bottom:.55rem; }
.compare-col li {
  font-size:.84rem; color:var(--ink-soft);
  list-style:none; padding:.18rem 0 .18rem 1rem;
  position:relative;
}
.compare-col li::before { content:'·'; position:absolute; left:0; font-weight:700; }

/* ─── INFO / WARN / DANGER ───────────────────────────────── */
.callout {
  display:flex; gap:.9rem; padding:.95rem 1.1rem;
  border-radius:0 10px 10px 0; margin:1rem 0;
  border-left:4px solid;
}
.callout-ico { font-size:1.2rem; flex-shrink:0; padding-top:.1rem; }
.callout-txt { font-size:.88rem; line-height:1.65; }
.callout.info  { background:#EBF5FB; border-color:#1A56C4; }
.callout.info .callout-txt  { color:#0D2D5A; }
.callout.warn  { background:#FEF9EC; border-color:#D4920A; }
.callout.warn .callout-txt  { color:#4A3000; }
.callout.danger{ background:#FEF0EE; border-color:#B5320D; }
.callout.danger .callout-txt{ color:#4A0D05; }

/* ─── QUESTIONS SECTION ──────────────────────────────────── */
.q-section {
  margin-top:2rem;
  border-top:2px dashed var(--border);
  padding-top:1.8rem;
}
.q-header {
  display:flex; align-items:center; gap:.75rem; margin-bottom:1.3rem;
}
.q-header h3 {
  font-family: Georgia, 'Times New Roman', serif; font-size:1.08rem; font-weight:700;
}
.q-count {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size:.68rem; font-weight:500; padding:.22rem .65rem;
  border-radius:20px; text-transform:uppercase; letter-spacing:.06em;
}
.q-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:.9rem;
}
@media(max-width:680px){ .q-grid{grid-template-columns:1fr;} }

.q-card {
  border-radius:10px; padding:1.1rem 1.2rem;
  border:1.5px solid transparent;
  transition: box-shadow .18s, transform .14s;
  position:relative; overflow:hidden;
}
.q-card:hover { transform:translateY(-2px); box-shadow:0 6px 22px rgba(0,0,0,.10); }
.q-card::before {
  content:''; position:absolute;
  top:0; left:0; right:0; height:3px;
}
.q-num {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size:.67rem; font-weight:500;
  letter-spacing:.1em; text-transform:uppercase;
  margin-bottom:.45rem; opacity:.65;
}
.q-text { font-size:.92rem; font-weight:600; line-height:1.5; margin-bottom:.65rem; }
.q-hint {
  font-size:.82rem; line-height:1.6;
  opacity:.7; border-top:1px solid rgba(0,0,0,.06);
  padding-top:.55rem; margin-top:.1rem;
}
.q-level {
  display:inline-block; font-size:.65rem; font-weight:600;
  padding:.18rem .55rem; border-radius:10px;
  text-transform:uppercase; letter-spacing:.06em; margin-top:.5rem;
}

/* ─── THEME COLORS ───────────────────────────────────────── */
/* NB1 — blue */
.t1 .nb-badge { background:#EBF0FD; }
.t1 .nb-num   { color:var(--c1); }
.t1 .tag.a    { background:#D6E3FF; color:#0C3A9A; }
.t1 .tag.b    { background:#EBF0FD; color:#1A56C4; }
.t1 .step     { border-left-color:var(--c1); }
.t1 .step-n   { background:#EBF0FD; color:var(--c1); }
.t1 .q-card   { background:#F6F9FF; border-color:#CFD9F5; }
.t1 .q-card::before { background:var(--c1); }
.t1 .q-num    { color:var(--c1); }
.t1 .q-level  { background:#D6E3FF; color:#0C3A9A; }
.t1 .q-count  { background:#D6E3FF; color:#0C3A9A; }
.t1 .nav-btn  { background:#EBF0FD; color:var(--c1); border-color:#BDD0F5; }
.t1 .nav-btn:hover { background:var(--c1); color:#fff; }

/* NB2 — rust */
.t2 .nb-badge { background:#FDEEE9; }
.t2 .nb-num   { color:var(--c2); }
.t2 .tag.a    { background:#FFD8CC; color:#6A1500; }
.t2 .tag.b    { background:#FDEEE9; color:var(--c2); }
.t2 .step     { border-left-color:var(--c2); }
.t2 .step-n   { background:#FDEEE9; color:var(--c2); }
.t2 .q-card   { background:#FFF5F2; border-color:#F5C9BC; }
.t2 .q-card::before { background:var(--c2); }
.t2 .q-num    { color:var(--c2); }
.t2 .q-level  { background:#FFD8CC; color:#6A1500; }
.t2 .q-count  { background:#FFD8CC; color:#6A1500; }
.t2 .nav-btn  { background:#FDEEE9; color:var(--c2); border-color:#F5C9BC; }
.t2 .nav-btn:hover { background:var(--c2); color:#fff; }

/* NB3 — green */
.t3 .nb-badge { background:#E7F6ED; }
.t3 .nb-num   { color:var(--c3); }
.t3 .tag.a    { background:#C8EDDA; color:#0A3D20; }
.t3 .tag.b    { background:#E7F6ED; color:var(--c3); }
.t3 .step     { border-left-color:var(--c3); }
.t3 .step-n   { background:#E7F6ED; color:var(--c3); }
.t3 .q-card   { background:#F3FBF6; border-color:#B8DFC8; }
.t3 .q-card::before { background:var(--c3); }
.t3 .q-num    { color:var(--c3); }
.t3 .q-level  { background:#C8EDDA; color:#0A3D20; }
.t3 .q-count  { background:#C8EDDA; color:#0A3D20; }
.t3 .nav-btn  { background:#E7F6ED; color:var(--c3); border-color:#B8DFC8; }
.t3 .nav-btn:hover { background:var(--c3); color:#fff; }

/* NB4 — purple */
.t4 .nb-badge { background:#F1EBFA; }
.t4 .nb-num   { color:var(--c4); }
.t4 .tag.a    { background:#DCCCF5; color:#2E1060; }
.t4 .tag.b    { background:#F1EBFA; color:var(--c4); }
.t4 .step     { border-left-color:var(--c4); }
.t4 .step-n   { background:#F1EBFA; color:var(--c4); }
.t4 .q-card   { background:#F8F4FE; border-color:#D4BCF2; }
.t4 .q-card::before { background:var(--c4); }
.t4 .q-num    { color:var(--c4); }
.t4 .q-level  { background:#DCCCF5; color:#2E1060; }
.t4 .q-count  { background:#DCCCF5; color:#2E1060; }
.t4 .nav-btn  { background:#F1EBFA; color:var(--c4); border-color:#D4BCF2; }
.t4 .nav-btn:hover { background:var(--c4); color:#fff; }

/* CASO1 — teal */
.t5 .nb-badge { background:#E5F4F7; }
.t5 .nb-num   { color:var(--c5); }
.t5 .tag.a    { background:#BEE8EF; color:#073D48; }
.t5 .tag.b    { background:#E5F4F7; color:var(--c5); }
.t5 .step     { border-left-color:var(--c5); }
.t5 .step-n   { background:#E5F4F7; color:var(--c5); }
.t5 .q-card   { background:#F1FAFC; border-color:#A8D8DF; }
.t5 .q-card::before { background:var(--c5); }
.t5 .q-num    { color:var(--c5); }
.t5 .q-level  { background:#BEE8EF; color:#073D48; }
.t5 .q-count  { background:#BEE8EF; color:#073D48; }
.t5 .nav-btn  { background:#E5F4F7; color:var(--c5); border-color:#A8D8DF; }
.t5 .nav-btn:hover { background:var(--c5); color:#fff; }

/* CASO2 — red */
.t6 .nb-badge { background:#FAE8E8; }
.t6 .nb-num   { color:var(--c6); }
.t6 .tag.a    { background:#F5C2C2; color:#500000; }
.t6 .tag.b    { background:#FAE8E8; color:var(--c6); }
.t6 .step     { border-left-color:var(--c6); }
.t6 .step-n   { background:#FAE8E8; color:var(--c6); }
.t6 .q-card   { background:#FDF3F3; border-color:#F0BEBE; }
.t6 .q-card::before { background:var(--c6); }
.t6 .q-num    { color:var(--c6); }
.t6 .q-level  { background:#F5C2C2; color:#500000; }
.t6 .q-count  { background:#F5C2C2; color:#500000; }
.t6 .nav-btn  { background:#FAE8E8; color:var(--c6); border-color:#F0BEBE; }
.t6 .nav-btn:hover { background:var(--c6); color:#fff; }

/* ─── FOOTER ─────────────────────────────────────────────── */
.footer {
  text-align:center; padding:2.5rem 1.5rem;
  border-top:1px solid var(--border);
  background:#fff; color:var(--muted); font-size:.84rem;
}
.footer strong { color:var(--ink); }

@media(max-width:600px){
  .nb-head { flex-direction:column; }
  .nb-body { padding:1.2rem; }
  .nb-head { padding:1.3rem; }
}
</style>
</head>
